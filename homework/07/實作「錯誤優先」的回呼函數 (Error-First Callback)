// 1. 定義 fetchData 函數
function fetchData(id, callback) {
    // 模擬資料庫回傳的資料
    const fakeData = {
        id: id,
        status: "success"
    };

    // 呼叫 callback（Error-First 慣例）
    callback(null, fakeData);
}

// 2. 執行 fetchData 並處理回傳結果
fetchData(101, (err, data) => {
    if (err) {
        console.log("發生錯誤：" + err);
    } else {
        console.log("成功取得資料：", data);
        // 成功取得資料： { id: 101, status: 'success' }
    }
});
