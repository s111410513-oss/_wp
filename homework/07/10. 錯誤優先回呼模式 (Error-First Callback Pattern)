function checkAdmin(role, callback) {
    if (role !== "admin") {
        return callback("Access Denied");
    }

    callback(null, "Welcome");
}

// 測試1：錯誤情況
checkAdmin("user", (err, result) => {
    if (err) {
        console.log("錯誤：", err);
    } else {
        console.log("成功：", result);
    }
});

// 測試2：成功情況
checkAdmin("admin", (err, result) => {
    if (err) {
        console.log("錯誤：", err);
    } else {
        console.log("成功：", result);
    }
});
